APP_ENV=docker
LOG_LEVEL=INFO

SECRET_KEY_FILE=/app-secrets/secret_key.txt

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

EMAIL_FROM=Sourcewise <no-reply@notifications.ibrahimherawi.com>
RESEND_API_KEY_FILE=/app-secrets/resend_api_key.txt
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PASSWORD_FILE=

AI_PROVIDER=ollama

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_API_KEY_FILE=/app-secrets/openai_api_key.txt

OLLAMA_CHAT_MODEL=llama3.2:1b
LLM_CONNECT_TIMEOUT_S=5
LLM_READ_TIMEOUT_S=60
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_MIN_WAIT_S=0.5
LLM_RETRY_MAX_WAIT_S=4
OLLAMA_EMBED_MODEL=nomic-embed-text

POSTGRES_USER=postgres
POSTGRES_DB=app_db
POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password

EMBEDDING_DIM=768
INGEST_WORKERS=2
INGEST_SHUTDOWN_TIMEOUT_S=30
EMBED_CONCURRENCY=4
OLLAMA_EMBED_BATCH_SIZE=32
OLLAMA_EMBED_READ_TIMEOUT_S=120
ANSWER_PROVIDER_TIMEOUT_S=60
RETRIEVAL_MAX_COSINE_DISTANCE=0.75
CHUNK_SIZE_CHARS=2000
CHUNK_OVERLAP_CHARS=100
TOP_K=5
MAX_UPLOAD_MB=10
